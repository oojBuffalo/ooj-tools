#!/usr/bin/env python3
"""dox - deterministic AGENTS.md tree engine.

A hierarchy of AGENTS.md files acts as a map of a codebase so a coding agent
loads only the docs relevant to the path it is touching, instead of the whole
repo. DOX (the original) is a prompt that asks the model to maintain this by
hand. This is the mechanistic version: the structure and the index are derived
from the filesystem, drift is detected by a script, and the model is only ever
asked to write prose - and only when this tool says it must.

Jobs and who does them:
  J1 load the right docs for a path   -> `dox context`  (deterministic)
  J2 keep the structural index right  -> `dox sync`     (deterministic)
  J3 keep the prose right             -> the agent, when `dox check` flags it

Each AGENTS.md documents a single domain (folder) with the conventional sections
from the DOX video - Purpose, Ownership, Local contracts (rules), Work guidance,
Test & verify - and ends with a Child Docs Index linking its subfolders. A folder
may opt into per-file docs (a sibling <file>.md per source file) by adding the
marker `<!-- dox:per-file -->` to its AGENTS.md.

Subcommands:
  init [--scaffold]  scaffold .dox.json + root AGENTS.md (+ a stub per folder)
  sync               regenerate the Child Docs Index in every AGENTS.md
  check              report drift: missing docs / stale index / dangling refs /
                     missing sections / missing per-file docs / prose drift
  context            print the root->path AGENTS.md chain (used by hooks and agents)

Stdlib only. No dependencies. Exit codes: 0 clean, 1 hard drift, 2 usage error.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
from pathlib import Path

DOC_NAME_DEFAULT = "AGENTS.md"
CONFIG_NAME = ".dox.json"
INDEX_OPEN = "<!-- dox:index -->"
INDEX_CLOSE = "<!-- /dox:index -->"
INDEX_HEADING = "## Child Docs Index"
PERFILE_MARKER = "<!-- dox:per-file -->"

# Canonical sections every domain doc carries, per the DOX video: purpose,
# ownership, local contracts (rules), work guidance, how to test and verify.
# Matched case-insensitively by the listed aliases so wording can vary.
SECTION_ALIASES = {
    "Purpose": ["purpose"],
    "Ownership": ["ownership", "parent"],
    "Local contracts": ["contract", "rules"],
    "Work guidance": ["guidance", "how to work"],
    "Test & verify": ["verify", "how to test"],
}

DEFAULT_CONFIG = {
    "doc_name": DOC_NAME_DEFAULT,
    "include": ["."],
    "required_sections": list(SECTION_ALIASES.keys()),
    "enforce_sections": True,
    "exclude": [
        ".git", "node_modules", "dist", "build", "out", "target",
        "__pycache__", ".venv", "venv", ".next", ".cache", "coverage",
    ],
    "code_exts": [
        ".py", ".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".go", ".rs",
        ".java", ".kt", ".rb", ".php", ".c", ".cc", ".cpp", ".h", ".hpp",
        ".cs", ".swift", ".scala", ".sh", ".sql",
    ],
    "require_docs_for_code_dirs": True,
}


# ---------- repo / config ----------

def find_root(start: Path) -> Path:
    start = start.resolve()
    for d in [start, *start.parents]:
        if (d / CONFIG_NAME).exists() or (d / ".git").exists():
            return d
    return start


def load_config(root: Path) -> dict:
    cfg = dict(DEFAULT_CONFIG)
    p = root / CONFIG_NAME
    if p.exists():
        try:
            cfg.update(json.loads(p.read_text(encoding="utf-8")))
        except json.JSONDecodeError as e:
            die(f"invalid {CONFIG_NAME}: {e}")
    return cfg


# ---------- scope ----------

def is_excluded(rel: Path, cfg: dict) -> bool:
    parts = set(rel.parts)
    return any(ex in parts for ex in cfg["exclude"])


def dir_has_code(d: Path, cfg: dict) -> bool:
    exts = set(cfg["code_exts"])
    try:
        return any(f.is_file() and f.suffix in exts for f in d.iterdir())
    except OSError:
        return False


def scope_dirs(root: Path, cfg: dict):
    """Yield every in-scope directory under the include roots.

    In-scope = directly contains code files, or already has a doc. The root
    directory is always in scope so there is a top of the tree.
    """
    doc = cfg["doc_name"]
    roots = [root / inc for inc in cfg["include"]]
    seen: set[Path] = set()
    for base in roots:
        if not base.exists():
            continue
        for dirpath, dirnames, _ in os.walk(base):
            d = Path(dirpath)
            rel = d.relative_to(root)
            # prune excluded dirs in-place so os.walk doesn't descend
            dirnames[:] = [
                n for n in dirnames
                if not is_excluded((rel / n), cfg)
            ]
            if is_excluded(rel, cfg):
                continue
            if d in seen:
                continue
            if d == root or dir_has_code(d, cfg) or (d / doc).exists():
                seen.add(d)
                yield d


# ---------- summaries / index ----------

def _clip(s: str, n: int = 140) -> str:
    s = s.strip()
    return s if len(s) <= n else s[: n - 3] + "..."


def summary_of(doc_path: Path) -> str:
    """The one-line purpose of a doc, for the parent index.

    Prefers the Purpose section text ('**Purpose** - ...' or a 'Purpose'
    heading's first line); falls back to the first plain prose line. This is
    what propagates a domain's purpose upward into its parent's Child Docs Index.
    """
    if not doc_path.exists():
        return ""
    lines = doc_path.read_text(encoding="utf-8").splitlines()
    # 1) inline label: **Purpose** - text   |   **Purpose:** text
    for raw in lines:
        m = re.match(r"\s*\*\*\s*purpose\s*\*\*\s*[:\-—]?\s*(.+)", raw, re.I)
        if m and m.group(1).strip():
            return _clip(m.group(1))
    # 2) a 'Purpose' heading, then the next prose line
    for i, raw in enumerate(lines):
        if re.match(r"\s*#+\s*purpose\b", raw, re.I):
            for nxt in lines[i + 1:]:
                t = nxt.strip()
                if t and not t.startswith(("#", "<!--")):
                    return _clip(t.lstrip("-*> ").strip())
            break
    # 3) fallback: first plain prose line outside the index block
    in_index = False
    for raw in lines:
        line = raw.strip()
        if line == INDEX_OPEN:
            in_index = True
            continue
        if line == INDEX_CLOSE:
            in_index = False
            continue
        if in_index or not line:
            continue
        if line.startswith(("#", "-", "*", ">", "```", "<!--", "|")):
            continue
        return _clip(line)
    return ""


def section_present(text: str, name: str) -> bool:
    t = text.lower()
    return any(k in t for k in SECTION_ALIASES.get(name, [name.lower()]))


def code_files(d: Path, cfg: dict) -> list[Path]:
    exts = set(cfg["code_exts"])
    try:
        return sorted(f for f in d.iterdir() if f.is_file() and f.suffix in exts)
    except OSError:
        return []


def is_perfile_dir(d: Path, cfg: dict) -> bool:
    dp = d / cfg["doc_name"]
    return dp.exists() and PERFILE_MARKER in dp.read_text(encoding="utf-8")


def child_areas(d: Path, root: Path, cfg: dict) -> list[tuple[str, str, bool]]:
    """Immediate child subareas of d: (name, summary, documented)."""
    doc = cfg["doc_name"]
    out = []
    try:
        children = sorted(p for p in d.iterdir() if p.is_dir())
    except OSError:
        return out
    for c in children:
        rel = c.relative_to(root)
        if is_excluded(rel, cfg):
            continue
        has_doc = (c / doc).exists()
        has_code = dir_has_code(c, cfg)
        # include if it is itself in scope or contains scoped descendants
        if has_doc or has_code or _has_scoped_descendant(c, root, cfg):
            out.append((c.name, summary_of(c / doc) if has_doc else "", has_doc))
    return out


def _has_scoped_descendant(d: Path, root: Path, cfg: dict) -> bool:
    doc = cfg["doc_name"]
    for dirpath, dirnames, _ in os.walk(d):
        cur = Path(dirpath)
        rel = cur.relative_to(root)
        dirnames[:] = [n for n in dirnames if not is_excluded((rel / n), cfg)]
        if is_excluded(rel, cfg):
            continue
        if cur != d and (dir_has_code(cur, cfg) or (cur / doc).exists()):
            return True
    return False


def gen_index(d: Path, root: Path, cfg: dict) -> str:
    doc = cfg["doc_name"]
    areas = child_areas(d, root, cfg)
    lines = [INDEX_OPEN,
             "<!-- generated by `dox sync` - do not edit by hand -->",
             INDEX_HEADING]
    body = []
    # Sub-domains (child folders).
    for name, summ, documented in areas:
        link = f"[`{name}/`]({name}/{doc})" if documented else f"`{name}/`"
        tail = f" - {summ}" if summ else (" - _(undocumented)_" if not documented else "")
        body.append(f"- {link}{tail}")
    # Per-file docs, when this folder opts into per-file documentation.
    if is_perfile_dir(d, cfg):
        for f in code_files(d, cfg):
            sib = d / (f.name + ".md")
            if sib.exists():
                body.append(f"- [`{f.name}`]({f.name}.md) - {summary_of(sib)}".rstrip(" -"))
            else:
                body.append(f"- `{f.name}` - _(undocumented)_")
    if not body:
        body.append("_Leaf domain - no children._")
    lines.extend(body)
    lines.append(INDEX_CLOSE)
    return "\n".join(lines)


# Markers are only recognised when alone on their own line, so prose that
# merely mentions the marker string (e.g. in a rules bullet) is never matched.
INDEX_BLOCK_RE = re.compile(
    r"^[ \t]*" + re.escape(INDEX_OPEN) + r"[ \t]*$.*?^[ \t]*" + re.escape(INDEX_CLOSE) + r"[ \t]*$",
    re.DOTALL | re.MULTILINE,
)


def replace_index(text: str, block: str) -> str:
    if INDEX_BLOCK_RE.search(text):
        return INDEX_BLOCK_RE.sub(lambda _: block, text, count=1)
    sep = "" if text.endswith("\n\n") else ("\n" if text.endswith("\n") else "\n\n")
    return text + sep + block + "\n"


# ---------- git ----------

def git_changed(root: Path, cfg: dict) -> set[Path]:
    """Files changed in the working tree + index, as paths relative to root."""
    if not (root / ".git").exists():
        return set()
    out: set[Path] = set()
    for args in (["diff", "--name-only"], ["diff", "--name-only", "--cached"]):
        try:
            r = subprocess.run(["git", *args], cwd=root,
                               capture_output=True, text=True, check=False)
        except FileNotFoundError:
            return set()
        for line in r.stdout.splitlines():
            if line.strip():
                out.add(Path(line.strip()))
    return out


# ---------- doc / link scanning ----------

LINK_RE = re.compile(r"\[[^\]]*\]\(([^)]+)\)")


def dangling_refs(doc_path: Path, cfg: dict) -> list[str]:
    bad = []
    base = doc_path.parent
    in_index = False
    for raw in doc_path.read_text(encoding="utf-8").splitlines():
        s = raw.strip()
        if s == INDEX_OPEN:
            in_index = True
            continue
        if s == INDEX_CLOSE:
            in_index = False
            continue
        if in_index:
            continue  # index links are machine-generated and verified by sync
        for m in LINK_RE.finditer(raw):
            target = m.group(1).split("#")[0].strip()
            if not target or target.startswith(("http://", "https://", "mailto:")):
                continue
            if not (base / target).exists():
                bad.append(target)
    return bad


# ---------- commands ----------

def cmd_init(root: Path, cfg: dict, args) -> int:
    cfgp = root / CONFIG_NAME
    if not cfgp.exists():
        cfgp.write_text(json.dumps(DEFAULT_CONFIG, indent=2) + "\n", encoding="utf-8")
        print(f"wrote {CONFIG_NAME}")
    doc = cfg["doc_name"]
    written = 0
    rootdoc = root / doc
    if not rootdoc.exists():
        rootdoc.write_text(ROOT_TEMPLATE, encoding="utf-8")
        written += 1
    if args.scaffold:
        # Stub a canonical-section doc in every in-scope folder, leaving prose
        # (J3) to the agent. Structure is deterministic; content is not.
        for d in scope_dirs(root, cfg):
            dp = d / doc
            if dp.exists():
                continue
            dp.write_text(stub_template(d.name if d != root else "Project"), encoding="utf-8")
            written += 1
    n = sync_all(root, cfg, write=True)
    print(f"wrote {written} doc stub(s), synced {n}. "
          f"Next: fill Purpose/contracts/etc. in each {doc}, then `dox check`."
          + ("" if args.scaffold else f"  (use `dox init --scaffold` to stub every folder)"))
    return 0


def sync_all(root: Path, cfg: dict, write: bool) -> int:
    doc = cfg["doc_name"]
    changed = 0
    for d in scope_dirs(root, cfg):
        dp = d / doc
        if not dp.exists():
            continue
        old = dp.read_text(encoding="utf-8")
        new = replace_index(old, gen_index(d, root, cfg))
        if new != old:
            changed += 1
            if write:
                dp.write_text(new, encoding="utf-8")
    return changed


def cmd_sync(root: Path, cfg: dict, args) -> int:
    n = sync_all(root, cfg, write=True)
    print(f"dox: synced index in {n} doc(s)")
    return 0


def cmd_check(root: Path, cfg: dict, args) -> int:
    doc = cfg["doc_name"]
    hard: list[str] = []
    warn: list[str] = []

    # missing docs for code-bearing dirs
    if cfg["require_docs_for_code_dirs"]:
        for d in scope_dirs(root, cfg):
            if (dir_has_code(d, cfg) or d == root) and not (d / doc).exists():
                hard.append(f"MISSING   {d.relative_to(root)}/ has code but no {doc}")

    # stale index + dangling refs + required sections + per-file docs
    for d in scope_dirs(root, cfg):
        dp = d / doc
        if not dp.exists():
            continue
        text = dp.read_text(encoding="utf-8")
        reld = dp.relative_to(root)
        if replace_index(text, gen_index(d, root, cfg)) != text:
            hard.append(f"STALE     {reld} index out of date (run `dox sync`)")
        for ref in dangling_refs(dp, cfg):
            hard.append(f"DANGLING  {reld} -> {ref} (missing)")
        if cfg.get("enforce_sections", True):
            missing = [s for s in cfg["required_sections"] if not section_present(text, s)]
            if missing:
                warn.append(f"SECTIONS  {reld} missing: {', '.join(missing)}")
        # per-file documentation: a sibling <file>.md per source file
        if is_perfile_dir(d, cfg):
            for f in code_files(d, cfg):
                if not (d / (f.name + ".md")).exists():
                    hard.append(f"FILEDOC   {(f.relative_to(root))} has no sibling {f.name}.md "
                                f"(folder is per-file)")

    # prose drift: code in a dir changed but its doc did not (git only)
    changed = git_changed(root, cfg)
    if changed:
        exts = set(cfg["code_exts"])
        touched_docs = {c for c in changed if c.name == doc}
        flagged: set[Path] = set()
        for c in changed:
            if c.suffix not in exts:
                continue
            d = (root / c).parent
            rel_doc = (d / doc).relative_to(root)
            if (d / doc).exists() and rel_doc not in touched_docs and rel_doc not in flagged:
                flagged.add(rel_doc)
                warn.append(f"PROSE?    {rel_doc} unchanged but code in {d.relative_to(root)}/ changed")

    for w in warn:
        print(f"dox: warn  {w}")
    for h in hard:
        print(f"dox: ERROR {h}")

    if hard:
        print(f"\ndox: {len(hard)} hard issue(s), {len(warn)} warning(s)")
        return 1
    if args.strict and warn:
        print(f"\ndox: {len(warn)} warning(s) (strict mode)")
        return 1
    print(f"dox: ok ({len(warn)} warning(s))" if warn else "dox: ok")
    return 0


def cmd_context(root: Path, cfg: dict, args) -> int:
    doc = cfg["doc_name"]
    target = Path(args.path)
    if not target.is_absolute():
        target = (Path.cwd() / target)
    target = target.resolve()
    base = target if target.is_dir() else target.parent
    try:
        rel = base.relative_to(root)
    except ValueError:
        rel = Path(".")
    chain = []
    cur = root
    for part in ("", *rel.parts):
        cur = cur / part if part else cur
        dp = cur / doc
        if dp.exists():
            chain.append(dp)
    if not chain:
        return 0
    for dp in chain:
        body = dp.read_text(encoding="utf-8")
        print(f"===== {dp.relative_to(root)} =====")
        print(body.rstrip())
        print()
    return 0


ROOT_TEMPLATE = f"""<!-- Your own project/agent instructions stay above. The DOX framework is appended below. -->

# DOX framework

You maintain a hierarchy of {DOC_NAME_DEFAULT} files coupled to the codebase - one per
folder - as a map of this repo. Each file documents a single domain and ends with a
Child Docs Index linking its subfolders.

- **Before editing** a path, read the {DOC_NAME_DEFAULT} chain from the root down to it
  (`dox context <path>`). Higher files give broad rules; deeper files give specifics.
- **After a meaningful change**, update the affected {DOC_NAME_DEFAULT}(s) - the closest one
  and any parent whose contract changed. `dox sync` regenerates the index blocks.
- Keep docs concise and current: stable contracts, not history. Delete stale content.
- Shared code in another branch of the tree may be linked from the index or a section.

## Purpose
What this repository is for (one line - this feeds the parent index).

## Ownership
Top-level. Owns repo-wide conventions.

## Local contracts (rules)
- Repo-wide rules an agent must not violate.

## Work guidance
- How to organize code, where things go.

## Test & verify
- How to test and verify changes.

{INDEX_OPEN}
{INDEX_CLOSE}
"""


def stub_template(name: str) -> str:
    return f"""# {name}

## Purpose
What `{name}/` is for (one line - this feeds the parent index).

## Ownership
Parent package / who owns this domain.

## Local contracts (rules)
- Rules specific to this folder (e.g. "return typed results, dataclasses or none").

## Work guidance
- How to work here, where to put things.

## Test & verify
- How to test and verify changes in this folder.

{INDEX_OPEN}
{INDEX_CLOSE}
"""


def die(msg: str) -> None:
    print(f"dox: {msg}", file=sys.stderr)
    sys.exit(2)


def main(argv=None) -> int:
    ap = argparse.ArgumentParser(prog="dox", description="deterministic AGENTS.md tree engine")
    ap.add_argument("-C", dest="chdir", default=".", help="run as if started in this dir")
    sub = ap.add_subparsers(dest="cmd", required=True)
    pi = sub.add_parser("init", help="scaffold config + root doc")
    pi.add_argument("--scaffold", action="store_true",
                    help="also stub a canonical-section AGENTS.md in every in-scope folder")
    sub.add_parser("sync", help="regenerate index blocks")
    pc = sub.add_parser("check", help="report drift")
    pc.add_argument("--strict", action="store_true", help="treat warnings as failures")
    pctx = sub.add_parser("context", help="print root->path doc chain")
    pctx.add_argument("path", help="file or directory the agent is about to touch")
    args = ap.parse_args(argv)

    start = Path(args.chdir).resolve()
    root = find_root(start)
    cfg = load_config(root)
    fn = {"init": cmd_init, "sync": cmd_sync, "check": cmd_check, "context": cmd_context}[args.cmd]
    return fn(root, cfg, args)


if __name__ == "__main__":
    sys.exit(main())
